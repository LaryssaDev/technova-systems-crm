rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: id, login, name, role, password
    //
    // Collection: clients
    // Fields: id, name, company, phone, email, segment, serviceType, contractValue, status, responsibleId, responsibleName, createdAt, notes
    //
    // Collection: goals
    // Fields: month, targetValue, reachedValue, isCompleted
    //
    // Collection: meetings
    // Fields: id, title, company, clientId, clientName, responsibleId, responsibleName, date, time, notes
    //
    // Collection: financialEntries
    // Fields: id, type, description, amount, category, paymentMethod, date, relatedClientId, responsibleId, notes
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
         (request.auth.token.email == "laryssaferreira7744@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Collection Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /goals/{goalId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /financialEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
